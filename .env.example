# Copy this file to .env and fill in your real values.
# .env is git-ignored, so your secrets stay on your machine.

# --- Google Gemini API ---
# Get a free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Optional: AI behavior ---
# Maximum number of AI calls allowed per session (cost guardrail)
AI_MAX_CALLS_PER_SESSION=20

# Gemini model name (free tier supports gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash
